#!/bin/sh
# Print the WuWei session user id from HTTP_COOKIE.
# This helper is called by other CGI scripts, so it must emit only the user id
# or an empty string.

export LC_ALL=C

trim() {
  sed 's/^[[:space:]]*//; s/[[:space:]]*$//'
}

user_id=$(
  printf '%s' "${HTTP_COOKIE:-}" \
    | tr ';' '\n' \
    | awk -F= '
        {
          key=$1
          sub(/^[ \t\r\n]+/, "", key)
          sub(/[ \t\r\n]+$/, "", key)
          if (key == "wuwei_user_id") {
            print $2
            exit
          }
        }
      ' \
    | trim \
    | tr -d '\r\n'
)

case "$user_id" in
  ????????-????-????-????-????????????)
    printf '%s\n' "$user_id"
    ;;
  *)
    printf '\n'
    ;;
esac

exit 0
